<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="enable_mapping" default="true" doc="Set true to run gmapping and save a map"/>
    <arg name="enable_nav" default="false" doc="Set true to run A* and Pure Pursuit"/>

    <arg name="enable_camera" default="true"/>
    <arg name="enable_perception" default="false"/>
    <arg name="enable_rviz" default="true"/>
    <arg name="publish_debug_img" default="false"/>
    <arg name="skip_frames" default="1"/>

    <arg name="parent_frame" default="world"/>
    <arg name="base_frame" default="camera_link"/>

    <arg name="map_yaml" default="/home/rfran/dev/maps/nice_map6.yaml"/>
    <arg name="map_pgm" default="/home/rfran/dev/maps/nice_map6.pgm"/>
    <arg name="waypoints" default="[]"/>
    <arg name="waypoints_file" default=""/>
    <arg name="loop_waypoints" default="false"/>
    <arg name="v_max" default="0.25"/>
    <arg name="lookahead" default="0.60"/>

    <!-- ═══════════════════════════════════════════════════════════════
         CAMERA
    ═══════════════════════════════════════════════════════════════════ -->
    <include file="$(find video_stream_opencv)/launch/camera.launch" if="$(arg enable_camera)">
        <arg name="camera_name" value="phone_cam"/>
        <arg name="video_stream_provider" value="http://10.195.242.220:5000/video"/>
        <arg name="fps" value="30"/>
        <arg name="width" value="640"/>
        <arg name="height" value="360"/>
    </include>

    <!-- ═══════════════════════════════════════════════════════════════
         ORB-SLAM3 — Mapping mode
         Publishes: /orb_slam3/all_points, /orb_slam3/pose, TF world→camera_link
    ═══════════════════════════════════════════════════════════════════ -->
    <node name="orb_slam3_mono" if="$(arg enable_mapping)" pkg="ORB_SLAM3" type="Mono"
          args="/home/rfran/dev/ORB_SLAM3/Vocabulary/ORBvoc.txt
                /home/rfran/dev/ORB_SLAM3/Examples/Monocular/TUM1_mapping.yaml"
          output="screen">
        <param name="parent_frame" value="$(arg parent_frame)"/>
        <param name="child_frame"  value="$(arg base_frame)"/>
        <remap from="/camera/image_raw" to="/phone_cam/image_raw"/>
        <param name="map_scale" value="100.0"/> <!-- 50.0 -->
        <param name="clip_min"  value="-0.3"/>
        <param name="clip_max"  value="0.3"/>
        <param name="map_path"  value="/home/rfran/dev/osa/final_map"/>
    </node>

    <!-- ═══════════════════════════════════════════════════════════════
         ORB-SLAM3 — Nav-only mode (localisation against existing atlas)
         Publishes: /orb_slam3/all_points, /orb_slam3/pose, TF world→camera_link
    ═══════════════════════════════════════════════════════════════════ -->
    <node name="orb_slam3_mono"
          if="$(eval arg('enable_nav') and not arg('enable_mapping'))"
          pkg="ORB_SLAM3" type="Mono"
          args="/home/rfran/dev/ORB_SLAM3/Vocabulary/ORBvoc.txt
                /home/rfran/dev/ORB_SLAM3/Examples/Monocular/TUM1_nav.yaml"
          output="screen">
        <remap from="/camera/image_raw" to="/phone_cam/image_raw"/>
        <param name="parent_frame" value="$(arg parent_frame)"/>
        <param name="child_frame"  value="$(arg base_frame)"/>
    </node>

    <!-- ═══════════════════════════════════════════════════════════════
         POINTCLOUD → LASERSCAN
         Moved OUTSIDE the mapping group so AMCL gets /scan in nav mode too.
         Active whenever mapping OR nav is running.
    ═══════════════════════════════════════════════════════════════════ -->
    <node if="$(eval arg('enable_mapping') or arg('enable_nav'))"
          pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
          name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/orb_slam3/all_points"/>
        <remap from="scan"     to="/scan"/>
        <rosparam>
            target_frame:        camera_link
            transform_tolerance: 0.05
            min_height:          -0.3
            max_height:           0.3
            angle_min:           -3.1415
            angle_max:            3.1415
            angle_increment:      0.0087
            scan_time:            0.0333
            range_min:            0.1
            range_max:            8.0
            use_inf:              false
            concurrency_level:    1
        </rosparam>
    </node>

    <!-- ═══════════════════════════════════════════════════════════════
         MAPPING GROUP  (gmapping only — pointcloud_to_laserscan moved above)
    ═══════════════════════════════════════════════════════════════════ -->
    <group if="$(arg enable_mapping)">
        <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
            <param name="map_frame"   value="map"/>
            <param name="odom_frame"  value="world"/>
            <param name="base_frame"  value="camera_link"/>
            <param name="map_update_interval" value="1.0"/>
            <param name="transform_tolerance" value="0.5"/>
            <param name="linearUpdate"  value="0.1"/>
            <param name="angularUpdate" value="0.1"/>
            <param name="temporalUpdate" value="1.0"/>
            <param name="maxUrange"  value="6.0"/>
            <param name="maxRange"   value="8.0"/>
            <param name="sigma"      value="0.05"/>
            <param name="kernelSize" value="1"/>
            <param name="lstep"      value="0.05"/>
            <param name="astep"      value="0.05"/>
            <param name="iterations" value="10"/>
            <param name="lsigma"     value="0.05"/>
            <param name="ogain"      value="3.0"/>
            <param name="lskip"      value="0"/>
            <param name="minimumScore"     value="100"/>
            <param name="srr"  value="0.05"/>
            <param name="srt"  value="0.05"/>
            <param name="str"  value="0.05"/>
            <param name="stt"  value="0.05"/>
            <param name="particles"        value="80"/>
            <param name="resampleThreshold" value="0.5"/>
            <param name="xmin"  value="-2.5"/>
            <param name="ymin"  value="-2.5"/>
            <param name="xmax"  value="2.5"/>
            <param name="ymax"  value="2.5"/>
            <param name="delta" value="0.05"/> 
            <remap from="scan" to="/scan"/>
        </node>
    </group>

    <!-- ═══════════════════════════════════════════════════════════════
         NAV GROUP  (map_server + AMCL + planners)
    ═══════════════════════════════════════════════════════════════════ -->
    <group if="$(arg enable_nav)">

        <!-- 1. Load the pre-saved occupancy map onto /map ─────────────
             Only needed when not simultaneously running gmapping.
             When enable_mapping is also true, gmapping publishes /map itself. -->
        <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_yaml)" output="screen"
              unless="$(arg enable_mapping)">
            <param name="frame_id" value="map"/>
        </node>

        <!-- 2. AMCL ────────────────────────────────────────────────────
             Subscribes : /scan, /map, TF world→camera_link (from ORB-SLAM3)
             Publishes  : TF map→world  (replaces the old static publisher)
                          /amcl_pose, /particlecloud

             ⚠ The static_transform_publisher for map→world has been REMOVED.
               AMCL owns that transform dynamically. Keeping the static one
               would cause TF conflicts and freeze localisation.
        -->
     <node pkg="amcl" type="amcl" name="amcl" output="screen"
          unless="$(arg enable_mapping)">   
            <!-- Frame IDs — must match the rest of your stack -->
            <param name="global_frame_id"  value="map"/>
            <param name="odom_frame_id"    value="world"/>       <!-- ORB-SLAM3 odometry frame -->
            <param name="base_frame_id"    value="camera_link"/>

            <!-- Odometry model — "omni" suits visual-odometry/ORB-SLAM3
                 better than "diff" because it allows lateral slip estimates -->
            <param name="odom_model_type"  value="omni"/>
            <param name="odom_alpha1"  value="0.05"/>   <!-- rot noise from rot -->
            <param name="odom_alpha2"  value="0.05"/>   <!-- rot noise from trans -->
            <param name="odom_alpha3"  value="0.05"/>   <!-- trans noise from trans -->
            <param name="odom_alpha4"  value="0.05"/>   <!-- trans noise from rot -->
            <param name="odom_alpha5"  value="0.05"/>   <!-- strafe noise (omni only) -->

            <!-- Laser model -->
            <param name="laser_model_type"             value="likelihood_field"/>
            <param name="laser_likelihood_max_dist"    value="2.0"/>
            <param name="laser_max_beams"              value="60"/>
            <param name="laser_min_range"              value="0.1"/>
            <param name="laser_max_range"              value="8.0"/>

            <!-- Particle filter -->
            <param name="min_particles"     value="500"/>
            <param name="max_particles"     value="3000"/>
            <param name="kld_err"           value="0.05"/>
            <param name="kld_z"             value="0.99"/>
            <param name="resample_interval" value="1"/>
            <param name="recovery_alpha_slow" value="0.001"/>
            <param name="recovery_alpha_fast" value="0.1"/>

            <!-- How often to publish the TF / pose -->
            <param name="transform_tolerance" value="0.5"/>
            <param name="gui_publish_rate"    value="10.0"/>
            <param name="save_pose_rate"      value="0.5"/>

            <!-- Set to true so AMCL spreads particles globally on first run
                 (instead of requiring a perfect initial pose estimate). -->
            <param name="initial_pose_x"   value="0.0"/>
            <param name="initial_pose_y"   value="0.0"/>
            <param name="initial_pose_a"   value="0.0"/>
            <param name="initial_cov_xx"   value="0.0"/>
            <param name="initial_cov_yy"   value="0.0"/>
            <param name="initial_cov_aa"   value="0.0"/>

            <remap from="scan" to="/scan"/>
        </node>

        <!-- 3. A* global planner ────────────────────────────────────── -->
        <node name="astar_planner" pkg="simple_nav" type="astar_planner.py"
              output="screen" respawn="true">
            <param name="parent_frame"   value="world"/>
            <!-- map_server handles /map, so these params only matter when
                 enable_mapping is also true and astar reads from gmapping. -->
            <param name="map_yaml_path"      value="$(arg map_yaml)"   unless="$(arg enable_mapping)"/>
            <param name="map_pgm_path"       value="$(arg map_pgm)"    unless="$(arg enable_mapping)"/>
            <param name="publish_map_topic"  value="/astar_map"              unless="$(arg enable_mapping)"/>
            <param name="base_frame"         value="$(arg base_frame)"/>
            <param name="goal_topic"         value="/move_base_simple/goal"/>
            <param name="path_topic"         value="/global_path"/>
            <param name="occupied_thresh"    value="65"/>
            <param name="treat_unknown_as_occupied" value="true"/>
            <param name="robot_radius"       value="0.05"/>
            <param name="inflation_extra"    value="0.00"/>
            <param name="allow_diagonal"     value="true"/>
        </node>

        <!-- 4. Pure Pursuit controller ──────────────────────────────── -->
        <node name="pure_pursuit" pkg="simple_nav" type="pure_pursuit.py"
              output="screen" respawn="true">
            <param name="parent_frame"   value="$(arg parent_frame)"/>
            <param name="base_frame"     value="$(arg base_frame)"/>
            <param name="path_topic"     value="/global_path"/>
            <param name="cmd_vel_topic"  value="/cmd_vel_raw"/>
            <param name="lookahead"      value="$(arg lookahead)"/>
            <param name="v_max"          value="$(arg v_max)"/>
            <param name="v_min"          value="0.05"/>
            <param name="w_max"          value="1.20"/>
            <param name="goal_tolerance" value="0.20"/>
            <param name="wheelbase"      value="0.26"/>
            <param name="publish_debug"  value="true"/>
            <param name="debug_ns"       value="pp"/>
        </node>

        <!-- 5. Obstacle stop ─────────────────────────────────────────── -->
        <node name="obstacle_stop" pkg="simple_nav" type="obstacle_stop.py"
              output="screen" respawn="true">
            <param name="parent_frame"        value="$(arg parent_frame)"/>
            <param name="base_frame"          value="$(arg base_frame)"/>
            <param name="cmd_vel_in_topic"    value="/cmd_vel_raw"/>
            <param name="cmd_vel_out_topic"   value="/cmd_vel"/>
            <param name="cloud_topic"         value="/orb_slam3/all_points"/>
            <param name="perception_topic"    value="/perception/nav_command"/>
            <param name="stop_distance"       value="0.60"/>
            <param name="lateral_half_width"  value="0.30"/>
            <param name="height_band"         value="0.50"/>
            <param name="min_points_to_stop"  value="3"/>
            <param name="clear_count_thresh"  value="5"/>
            <param name="slow_speed_fraction" value="0.35"/>
            <param name="perception_timeout"  value="1.0"/>
        </node>

        <!-- 6. Waypoint manager ──────────────────────────────────────── -->
        <node name="waypoint_manager" pkg="simple_nav" type="waypoint_manager.py"
              output="screen" respawn="true">
            <param name="parent_frame"   value="$(arg parent_frame)"/>
            <param name="base_frame"     value="$(arg base_frame)"/>
            <param name="goal_topic"     value="/move_base_simple/goal"/>
            <param name="odom_topic"     value="/orb_slam3/pose"/>
            <param name="waypoints_file" value="$(arg waypoints_file)"/>
            <rosparam param="waypoints" subst_value="True">$(arg waypoints)</rosparam>
            <param name="use_move_base"  value="false"/>
            <param name="goal_tolerance" value="0"/>
            <param name="loop_waypoints" value="$(arg loop_waypoints)"/>
        </node>

    </group>

    <!-- ═══════════════════════════════════════════════════════════════
         PERCEPTION (optional)
    ═══════════════════════════════════════════════════════════════════ -->
    <node name="perception_node" pkg="simple_nav" type="perception_node.py"
          output="screen" respawn="true" if="$(arg enable_perception)">
        <param name="image_topic"      value="/phone_cam/image_raw"/>
        <param name="model_path"       value="/home/rfran/slam_ws/src/detection/AV-Robots-Distance_Detection-Mandap/best_ncnn_model"/>
        <param name="calib_path"       value="/home/rfran/slam_ws/src/detection/AV-Robots-Distance_Detection-Mandap/calibration_params.npz"/>
        <param name="camera_height_m"  value="0.23"/>
        <param name="camera_tilt_deg"  value="12.0"/>
        <param name="target_width"     value="640"/>
        <param name="target_height"    value="360"/>
        <param name="skip_frames"      value="$(arg skip_frames)"/>
        <param name="publish_debug_img" value="$(arg publish_debug_img)"/>
    </node>

    <!-- ═══════════════════════════════════════════════════════════════
         RViz
    ═══════════════════════════════════════════════════════════════════ -->
    <node name="rviz" pkg="rviz" type="rviz"
          args="-d /home/rfran/dev/ORB_SLAM3/Examples/ROS/ORB_SLAM3/orb_grid_setup.rviz"
          if="$(arg enable_rviz)"/>

</launch>